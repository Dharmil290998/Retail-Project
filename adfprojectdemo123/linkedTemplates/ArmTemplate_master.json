{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfprojectdemo123"
		},
		"DataLakeStorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DataLakeStorage'"
		},
		"AzureKeyVault_SQLdatabase_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://keyvaultproject123.vault.azure.net/"
		},
		"AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://keyvaultretailproject.vault.azure.net/"
		},
		"AzureKeyVaultforSQLdatabase_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://keyvaultretailproject.vault.azure.net/"
		},
		"SqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "dnpserverdemo.database.windows.net"
		},
		"SqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dnpdatabase"
		},
		"SqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "dnpserver"
		},
		"DataLakeStorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://project1demo.dfs.core.windows.net/"
		},
		"RestService_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfprojectdemo123_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"DataLakeStorage_accountKey": {
						"value": "[parameters('DataLakeStorage_accountKey')]"
					},
					"AzureKeyVault_SQLdatabase_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault_SQLdatabase_properties_typeProperties_baseUrl')]"
					},
					"AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"AzureKeyVaultforSQLdatabase_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVaultforSQLdatabase_properties_typeProperties_baseUrl')]"
					},
					"DataLakeStorage_properties_typeProperties_url": {
						"value": "[parameters('DataLakeStorage_properties_typeProperties_url')]"
					},
					"RestService_properties_typeProperties_url": {
						"value": "[parameters('RestService_properties_typeProperties_url')]"
					},
					"SqlDatabase1_properties_typeProperties_server": {
						"value": "[parameters('SqlDatabase1_properties_typeProperties_server')]"
					},
					"SqlDatabase1_properties_typeProperties_database": {
						"value": "[parameters('SqlDatabase1_properties_typeProperties_database')]"
					},
					"SqlDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('SqlDatabase1_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}